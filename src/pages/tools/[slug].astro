import BasicAuthGenerator from "../../components/tools/islands/BasicAuthGenerator";
import OgMetaGenerator from "../../components/tools/islands/OgMetaGenerator";
import OtpGenerator from "../../components/tools/islands/OtpGenerator";
import MimeTypes from "../../components/tools/islands/MimeTypes";
import JwtParser from "../../components/tools/islands/JwtParser";
import KeycodeInfo from "../../components/tools/islands/KeycodeInfo";
import SlugifyString from "../../components/tools/islands/SlugifyString";
import HtmlWysiwygEditor from "../../components/tools/islands/HtmlWysiwygEditor";
import UserAgentParser from "../../components/tools/islands/UserAgentParser";
import HttpStatusCodes from "../../components/tools/islands/HttpStatusCodes";
import JsonDiff from "../../components/tools/islands/JsonDiff";
import SafelinkDecoder from "../../components/tools/islands/SafelinkDecoder";
import GitMemo from "../../components/tools/islands/GitMemo";
import RandomPortGenerator from "../../components/tools/islands/RandomPortGenerator";
import CrontabGenerator from "../../components/tools/islands/CrontabGenerator";
import JsonPrettify from "../../components/tools/islands/JsonPrettify";
import JsonMinify from "../../components/tools/islands/JsonMinify";
import JsonToCsv from "../../components/tools/islands/JsonToCsv";
import SqlPrettify from "../../components/tools/islands/SqlPrettify";
import ChmodCalculator from "../../components/tools/islands/ChmodCalculator";
import DockerRunToDockerComposeConverter from "../../components/tools/islands/DockerRunToDockerComposeConverter";
import XmlFormatter from "../../components/tools/islands/XmlFormatter";
import YamlPrettify from "../../components/tools/islands/YamlPrettify";
import EmailNormalizer from "../../components/tools/islands/EmailNormalizer";
import RegexTester from "../../components/tools/islands/RegexTester";
import RegexMemo from "../../components/tools/islands/RegexMemo";
import Ipv4SubnetCalculator from "../../components/tools/islands/Ipv4SubnetCalculator";
import Ipv4AddressConverter from "../../components/tools/islands/Ipv4AddressConverter";
import Ipv4RangeExpander from "../../components/tools/islands/Ipv4RangeExpander";
import MacAddressLookup from "../../components/tools/islands/MacAddressLookup";
import MacAddressGenerator from "../../components/tools/islands/MacAddressGenerator";
import Ipv6UlaGenerator from "../../components/tools/islands/Ipv6UlaGenerator";
import PercentageCalculator from "../../components/tools/islands/PercentageCalculator";
import EtaCalculator from "../../components/tools/islands/EtaCalculator";
import MathEvaluator from "../../components/tools/islands/MathEvaluator";
import TemperatureConverter from "../../components/tools/islands/TemperatureConverter";
import { availableTools, type Tool } from "../../content/tools";


export function getStaticPaths() {
  return availableTools().map((tool) => ({
    params: { slug: tool.id },
    props: { tool },
  }));
}

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const slug = tool.id;
---

<BaseLayout title={tool.title} description={tool.description}>
  <section class="tools-page" aria-labelledby="tool-heading">
    <PageIntro
      client:visible
      title={tool.title}
      titleId="tool-heading"
      lede={tool.description}
    />

    <ToolsShell activeSlug={slug}>
      <div class="tool-stage">
        <p class="tool-stage__eyebrow">Tool</p>

        {/* Island mounts — one React island per available tool slug. */}
        {
          slug === "word-code-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <WordCodeGenerator client:load />
            </div>
          ) : slug === "qrcode-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <QRCodeGenerator client:load />
            </div>
          ) : slug === "svg-placeholder-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <SvgPlaceholderGenerator client:load />
            </div>
          ) : slug === "camera-recorder" ? (
            <div class="tool-mount" data-tool={slug}>
              <CameraRecorder client:load />
            </div>
          ) : slug === "token-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <TokenGenerator client:load />
            </div>
          ) : slug === "hash-text" ? (
            <div class="tool-mount" data-tool={slug}>
              <HashText client:load />
            </div>
          ) : slug === "bcrypt" ? (
            <div class="tool-mount" data-tool={slug}>
              <Bcrypt client:load />
            </div>
          ) : slug === "uuid-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <UuidGenerator client:load />
            </div>
          ) : slug === "ulid-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <UlidGenerator client:load />
            </div>
          ) : slug === "password-strength-analyser" ? (
            <div class="tool-mount" data-tool={slug}>
              <PasswordStrengthAnalyser client:load />
            </div>
          ) : slug === "hmac-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <HmacGenerator client:load />
            </div>
          ) : slug === "encryption" ? (
            <div class="tool-mount" data-tool={slug}>
              <Encryption client:load />
            </div>
          ) : slug === "bip39-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <Bip39Generator client:load />
            </div>
          ) : slug === "rsa-key-pair-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <RsaKeyPairGenerator client:load />
            </div>
          ) : slug === "pdf-signature-checker" ? (
            <div class="tool-mount" data-tool={slug}>
              {/* client:only — pdf-signature-reader / node-forge must not enter Worker SSR */}
              <PdfSignatureChecker client:only="react" />
            </div>
          ) : slug === "text-to-nato-alphabet" ? (
            <div class="tool-mount" data-tool={slug}>
              <TextToNatoAlphabet client:load />
            </div>
          ) : slug === "text-to-binary" ? (
            <div class="tool-mount" data-tool={slug}>
              <TextToBinary client:load />
            </div>
          ) : slug === "text-to-unicode" ? (
            <div class="tool-mount" data-tool={slug}>
              <TextToUnicode client:load />
            </div>
          ) : slug === "roman-numeral-converter" ? (
            <div class="tool-mount" data-tool={slug}>
              <RomanNumeralConverter client:load />
            </div>
          ) : slug === "base-converter" ? (
            <div class="tool-mount" data-tool={slug}>
              <BaseConverter client:load />
            </div>
          ) : slug === "list-converter" ? (
            <div class="tool-mount" data-tool={slug}>
              <ListConverter client:load />
            </div>
          ) : slug === "base64-string-converter" ? (
            <div class="tool-mount" data-tool={slug}>
              <Base64StringConverter client:load />
            </div>
          ) : slug === "base64-file-converter" ? (
            <div class="tool-mount" data-tool={slug}>
              <Base64FileConverter client:load />
            </div>
          ) : slug === "case-converter" ? (
            <div class="tool-mount" data-tool={slug}>
              <CaseConverter client:load />
            </div>
          ) : slug === "date-converter" ? (
            <div class="tool-mount" data-tool={slug}>
              <DateConverter client:load />
            </div>
          ) : slug === "color-converter" ? (
            <div class="tool-mount" data-tool={slug}>
              <ColorConverter client:load />
            </div>
          ) : slug === "yaml-to-json-converter" ? (
            <div class="tool-mount" data-tool={slug}>
              <YamlToJsonConverter client:load />
            </div>
          ) : slug === "json-to-yaml-converter" ? (
            <div class="tool-mount" data-tool={slug}>
              <JsonToYamlConverter client:load />
            </div>
          ) : slug === "json-to-toml" ? (
            <div class="tool-mount" data-tool={slug}>
              <JsonToToml client:load />
            </div>
          ) : slug === "toml-to-json" ? (
            <div class="tool-mount" data-tool={slug}>
              <TomlToJson client:load />
            </div>
          ) : slug === "toml-to-yaml" ? (
            <div class="tool-mount" data-tool={slug}>
              <TomlToYaml client:load />
            </div>
          ) : slug === "yaml-to-toml" ? (
            <div class="tool-mount" data-tool={slug}>
              <YamlToToml client:load />
            </div>
          ) : slug === "xml-to-json" ? (
            <div class="tool-mount" data-tool={slug}>
              <XmlToJson client:load />
            </div>
          ) : slug === "json-to-xml" ? (
            <div class="tool-mount" data-tool={slug}>
              <JsonToXml client:load />
            </div>
          ) : slug === "markdown-to-html" ? (
            <div class="tool-mount" data-tool={slug}>
              <MarkdownToHtml client:load />
            </div>
          ) : slug === "url-encoder" ? (
            <div class="tool-mount" data-tool={slug}>
              <UrlEncoder client:load />
            </div>
          ) : slug === "html-entities" ? (
            <div class="tool-mount" data-tool={slug}>
              <HtmlEntities client:load />
            </div>
          ) : slug === "url-parser" ? (
            <div class="tool-mount" data-tool={slug}>
              <UrlParser client:load />
            </div>
          ) : slug === "device-information" ? (
            <div class="tool-mount" data-tool={slug}>
              <DeviceInformation client:load />
            </div>
          ) : slug === "basic-auth-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <BasicAuthGenerator client:load />
            </div>
          ) : slug === "og-meta-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <OgMetaGenerator client:load />
            </div>
          ) : slug === "otp-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <OtpGenerator client:load />
            </div>
          ) : slug === "mime-types" ? (
            <div class="tool-mount" data-tool={slug}>
              <MimeTypes client:load />
            </div>
          ) : slug === "jwt-parser" ? (
            <div class="tool-mount" data-tool={slug}>
              <JwtParser client:load />
            </div>
          ) : slug === "keycode-info" ? (
            <div class="tool-mount" data-tool={slug}>
              <KeycodeInfo client:load />
            </div>
          ) : slug === "slugify-string" ? (
            <div class="tool-mount" data-tool={slug}>
              <SlugifyString client:load />
            </div>
          ) : slug === "html-wysiwyg-editor" ? (
            <div class="tool-mount" data-tool={slug}>
              <HtmlWysiwygEditor client:load />
            </div>
          ) : slug === "user-agent-parser" ? (
            <div class="tool-mount" data-tool={slug}>
              <UserAgentParser client:load />
            </div>
          ) : slug === "http-status-codes" ? (
            <div class="tool-mount" data-tool={slug}>
              <HttpStatusCodes client:load />
            </div>
          ) : slug === "json-diff" ? (
            <div class="tool-mount" data-tool={slug}>
              <JsonDiff client:load />
            </div>
          ) : slug === "safelink-decoder" ? (
            <div class="tool-mount" data-tool={slug}>
              <SafelinkDecoder client:load />
            </div>
          ) : slug === "git-memo" ? (
            <div class="tool-mount" data-tool={slug}>
              <GitMemo client:load />
            </div>
          ) : slug === "random-port-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <RandomPortGenerator client:load />
            </div>
          ) : slug === "crontab-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <CrontabGenerator client:load />
            </div>
          ) : slug === "json-prettify" ? (
            <div class="tool-mount" data-tool={slug}>
              <JsonPrettify client:load />
            </div>
          ) : slug === "json-minify" ? (
            <div class="tool-mount" data-tool={slug}>
              <JsonMinify client:load />
            </div>
          ) : slug === "json-to-csv" ? (
            <div class="tool-mount" data-tool={slug}>
              <JsonToCsv client:load />
            </div>
          ) : slug === "sql-prettify" ? (
            <div class="tool-mount" data-tool={slug}>
              <SqlPrettify client:load />
            </div>
          ) : slug === "chmod-calculator" ? (
            <div class="tool-mount" data-tool={slug}>
              <ChmodCalculator client:load />
            </div>
          ) : slug === "docker-run-to-docker-compose-converter" ? (
            <div class="tool-mount" data-tool={slug}>
              <DockerRunToDockerComposeConverter client:load />
            </div>
          ) : slug === "xml-formatter" ? (
            <div class="tool-mount" data-tool={slug}>
              <XmlFormatter client:load />
            </div>
          ) : slug === "yaml-prettify" ? (
            <div class="tool-mount" data-tool={slug}>
              <YamlPrettify client:load />
            </div>
          ) : slug === "email-normalizer" ? (
            <div class="tool-mount" data-tool={slug}>
              <EmailNormalizer client:load />
            </div>
          ) : slug === "regex-tester" ? (
            <div class="tool-mount" data-tool={slug}>
              <RegexTester client:load />
            </div>
          ) : slug === "regex-memo" ? (
            <div class="tool-mount" data-tool={slug}>
              <RegexMemo client:load />
            </div>
          ) : slug === "ipv4-subnet-calculator" ? (
            <div class="tool-mount" data-tool={slug}>
              <Ipv4SubnetCalculator client:load />
            </div>
          ) : slug === "ipv4-address-converter" ? (
            <div class="tool-mount" data-tool={slug}>
              <Ipv4AddressConverter client:load />
            </div>
          ) : slug === "ipv4-range-expander" ? (
            <div class="tool-mount" data-tool={slug}>
              <Ipv4RangeExpander client:load />
            </div>
          ) : slug === "mac-address-lookup" ? (
            <div class="tool-mount" data-tool={slug}>
              <MacAddressLookup client:load />
            </div>
          ) : slug === "mac-address-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <MacAddressGenerator client:load />
            </div>
          ) : slug === "ipv6-ula-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <Ipv6UlaGenerator client:load />
            </div>
          ) : slug === "percentage-calculator" ? (
            <div class="tool-mount" data-tool={slug}>
              <PercentageCalculator client:load />
            </div>
          ) : slug === "eta-calculator" ? (
            <div class="tool-mount" data-tool={slug}>
              <EtaCalculator client:load />
            </div>
          ) : slug === "math-evaluator" ? (
            <div class="tool-mount" data-tool={slug}>
              <MathEvaluator client:load />
            </div>
          ) : slug === "temperature-converter" ? (
            <div class="tool-mount" data-tool={slug}>
              <TemperatureConverter client:load />
            </div>
          ) : (
            <div class="tool-mount" data-tool={slug}>
              <p class="tool-mount__note">Unknown tool.</p>
            </div>
          )
        }
      </div>
    </ToolsShell>
  </section>
</BaseLayout>

<style>
  .tools-page {
    display: grid;
    gap: var(--space-2xl);
  }

  .tools-page :global(.page-intro) {
    margin-bottom: 0;
  }

  /* Named tool-stage (not tool-workspace) to avoid clashing with shared island CSS */
  .tool-stage {
    display: grid;
    gap: var(--space-lg);
  }

  .tool-stage__eyebrow {
    margin: 0;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .tool-mount {
    display: grid;
    gap: var(--space-md);
    min-height: 12rem;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  .tool-mount__note {
    margin: 0;
    max-width: 48ch;
    color: var(--color-stone);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .tool-mount__note code {
    font-size: 0.9em;
    color: var(--color-ink);
  }
</style>
