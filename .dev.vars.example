# Local secrets for Astro + Cloudflare (never commit real values)
# Copy to `.dev.vars` and fill in:
#
#   cp .dev.vars.example .dev.vars
#
# Production:
#   npx wrangler secret put OPENCODE_API_KEY
#   npx wrangler secret put EXA_API_KEY
#   npx wrangler secret put CONTEXT7_API_KEY
#
# Optional: REQUIRE_ACCESS=1 forces API 401 without Access email header.
# Leave unset for local miniflare / astro dev.

OPENCODE_API_KEY=
EXA_API_KEY=
CONTEXT7_API_KEY=
# REQUIRE_ACCESS=
