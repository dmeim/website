---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolsShell from "../../components/tools/ToolsShell";
import { availableTools, getToolById, type Tool } from "../../content/tools";

export function getStaticPaths() {
  return availableTools().map((tool) => ({
    params: { slug: tool.id },
    props: { tool },
  }));
}

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const resolved = getToolById(tool.id) ?? tool;
---

<BaseLayout title={resolved.title} description={resolved.description} immersive>
  <ToolsShell client:only="react" initialSlug={resolved.id} />
</BaseLayout>
