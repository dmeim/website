---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageIntro from "../../components/react/PageIntro";
import ToolsShell from "../../components/tools/ToolsShell.astro";
import WordCodeGenerator from "../../components/tools/islands/WordCodeGenerator";
import QRCodeGenerator from "../../components/tools/islands/QRCodeGenerator";
import SvgPlaceholderGenerator from "../../components/tools/islands/SvgPlaceholderGenerator";
import CameraRecorder from "../../components/tools/islands/CameraRecorder";
import TokenGenerator from "../../components/tools/islands/TokenGenerator";
import HashText from "../../components/tools/islands/HashText";
import Bcrypt from "../../components/tools/islands/Bcrypt";
import UuidGenerator from "../../components/tools/islands/UuidGenerator";
import UlidGenerator from "../../components/tools/islands/UlidGenerator";
import PasswordStrengthAnalyser from "../../components/tools/islands/PasswordStrengthAnalyser";
import HmacGenerator from "../../components/tools/islands/HmacGenerator";
import { availableTools, type Tool } from "../../content/tools";

export function getStaticPaths() {
  return availableTools().map((tool) => ({
    params: { slug: tool.id },
    props: { tool },
  }));
}

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const slug = tool.id;
---

<BaseLayout title={tool.title} description={tool.description}>
  <section class="tools-page" aria-labelledby="tool-heading">
    <PageIntro
      client:visible
      title={tool.title}
      titleId="tool-heading"
      lede={tool.description}
    />

    <ToolsShell activeSlug={slug}>
      <div class="tool-stage">
        <p class="tool-stage__eyebrow">Tool</p>

        {/* Island mounts — one React island per available tool slug. */}
        {
          slug === "word-code-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <WordCodeGenerator client:load />
            </div>
          ) : slug === "qrcode-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <QRCodeGenerator client:load />
            </div>
          ) : slug === "svg-placeholder-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <SvgPlaceholderGenerator client:load />
            </div>
          ) : slug === "camera-recorder" ? (
            <div class="tool-mount" data-tool={slug}>
              <CameraRecorder client:load />
            </div>
          ) : slug === "token-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <TokenGenerator client:load />
            </div>
          ) : slug === "hash-text" ? (
            <div class="tool-mount" data-tool={slug}>
              <HashText client:load />
            </div>
          ) : slug === "bcrypt" ? (
            <div class="tool-mount" data-tool={slug}>
              <Bcrypt client:load />
            </div>
          ) : slug === "uuid-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <UuidGenerator client:load />
            </div>
          ) : slug === "ulid-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <UlidGenerator client:load />
            </div>
          ) : slug === "password-strength-analyser" ? (
            <div class="tool-mount" data-tool={slug}>
              <PasswordStrengthAnalyser client:load />
            </div>
          ) : slug === "hmac-generator" ? (
            <div class="tool-mount" data-tool={slug}>
              <HmacGenerator client:load />
            </div>
          ) : (
            <div class="tool-mount" data-tool={slug}>
              <p class="tool-mount__note">Unknown tool.</p>
            </div>
          )
        }
      </div>
    </ToolsShell>
  </section>
</BaseLayout>

<style>
  .tools-page {
    display: grid;
    gap: var(--space-2xl);
  }

  .tools-page :global(.page-intro) {
    margin-bottom: 0;
  }

  /* Named tool-stage (not tool-workspace) to avoid clashing with shared island CSS */
  .tool-stage {
    display: grid;
    gap: var(--space-lg);
  }

  .tool-stage__eyebrow {
    margin: 0;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .tool-mount {
    display: grid;
    gap: var(--space-md);
    min-height: 12rem;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  .tool-mount__note {
    margin: 0;
    max-width: 48ch;
    color: var(--color-stone);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .tool-mount__note code {
    font-size: 0.9em;
    color: var(--color-ink);
  }
</style>
