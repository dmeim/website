---
import ToolsSidebar from "./ToolsSidebar.astro";

interface Props {
  activeSlug?: string;
}

const { activeSlug } = Astro.props;
---

<div class="tools-shell">
  <ToolsSidebar activeSlug={activeSlug} />
  <div class="tools-shell__panel tools-shell__panel--main">
    <slot />
  </div>
</div>

<style>
  .tools-shell {
    display: grid;
    grid-template-columns: minmax(12rem, 0.22fr) minmax(0, 0.78fr);
    gap: var(--space-lg);
    align-items: start;
    min-height: 28rem;
  }

  /* Shared panel chrome — :global so it reaches ToolsSidebar root */
  .tools-shell :global(.tools-shell__panel) {
    border: 1px solid var(--color-border);
    background:
      radial-gradient(
        ellipse 70% 50% at 0% 0%,
        var(--color-spot),
        transparent 55%
      ),
      color-mix(in srgb, var(--color-ground-elevated) 88%, transparent);
    min-width: 0;
  }

  .tools-shell__panel--main {
    padding: var(--space-lg);
    min-height: 24rem;
  }

  @media (max-width: 900px) {
    .tools-shell {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .tools-shell :global(.tools-sidebar) {
      display: none;
    }

    .tools-shell__panel--main {
      padding: var(--space-md);
    }
  }
</style>
