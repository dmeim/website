# Public site URL (optional; used for absolute links / SEO when set)
# PUBLIC_SITE_URL=https://dmeim.com

# Connect email / GitHub live in src/content/site.ts (not env).
# Edit `connect.email` and `connect.socialUrl` there.

# n8n webhook for the connect form (client POST JSON: name, email, subject, message)
# Leave unset to validate the form without submitting (shows “not connected yet”)
# PUBLIC_N8N_WEBHOOK_URL=https://your-n8n.example/webhook/connect
