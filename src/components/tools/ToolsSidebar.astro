---
import {
  availableTools,
  plannedTools,
  toolCategories,
  toolRoute,
} from "../../content/tools";

interface Props {
  activeSlug?: string;
}

const { activeSlug } = Astro.props;
const availableCount = availableTools().length;
const plannedCount = plannedTools().length;
---

<aside class="tools-sidebar tools-shell__panel" aria-label="Tool categories">
  <div class="tools-sidebar__head">
    <p class="tools-sidebar__eyebrow">Catalogue</p>
    <h2 class="tools-sidebar__title">Tools</h2>
    <p class="tools-sidebar__meta">
      {availableCount} ready · {plannedCount} WIP
    </p>
  </div>

  <a
    class:list={[
      "tools-sidebar__home",
      { "is-active": !activeSlug },
    ]}
    href="/tools"
  >
    All tools
  </a>

  <nav class="tools-sidebar__nav" aria-label="Categories">
    {
      toolCategories.map((category) => (
        <details class="tools-sidebar__category">
          <summary>
            <span class="tools-sidebar__category-name">{category.name}</span>
            <span class="tools-sidebar__category-count">
              {category.tools.length}
            </span>
          </summary>
          <ul class="tools-sidebar__list" role="list">
            {category.tools.map((tool) => {
              const href = toolRoute(tool);
              const isActive = activeSlug === tool.id;
              if (href) {
                return (
                  <li>
                    <a
                      class:list={[
                        "tools-sidebar__item",
                        "is-available",
                        { "is-active": isActive },
                      ]}
                      href={href}
                      aria-current={isActive ? "page" : undefined}
                    >
                      <span class="tools-sidebar__item-label">{tool.title}</span>
                    </a>
                  </li>
                );
              }
              return (
                <li>
                  <span
                    class="tools-sidebar__item is-wip"
                    title="Work in progress"
                  >
                    <span class="tools-sidebar__item-label">{tool.title}</span>
                    <span class="tools-sidebar__badge">WIP</span>
                  </span>
                </li>
              );
            })}
          </ul>
        </details>
      ))
    }
  </nav>
</aside>

<style>
  .tools-sidebar {
    position: sticky;
    top: calc(var(--header-height) + var(--space-md));
    align-self: start;
    max-height: calc(100vh - var(--header-height) - var(--space-xl));
    overflow: auto;
    padding: var(--space-md);
    display: grid;
    gap: var(--space-md);
    align-content: start;
  }

  .tools-sidebar__head {
    display: grid;
    gap: var(--space-2xs);
  }

  .tools-sidebar__eyebrow {
    margin: 0;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .tools-sidebar__title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 1.35rem;
    letter-spacing: -0.01em;
  }

  .tools-sidebar__meta {
    margin: 0;
    color: var(--color-ink-muted);
    font-size: 0.8125rem;
  }

  .tools-sidebar__home {
    display: block;
    padding: var(--space-xs) 0;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-ink-muted);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color var(--duration) var(--ease-out);
  }

  .tools-sidebar__home:hover,
  .tools-sidebar__home.is-active {
    color: var(--color-accent);
  }

  .tools-sidebar__nav {
    display: grid;
    gap: var(--space-2xs);
  }

  .tools-sidebar__category {
    border-bottom: 1px solid var(--color-border);
  }

  .tools-sidebar__category:last-child {
    border-bottom: 0;
  }

  .tools-sidebar__category summary {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding-block: var(--space-sm);
    cursor: pointer;
    list-style: none;
    color: var(--color-ink);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .tools-sidebar__category summary::-webkit-details-marker {
    display: none;
  }

  .tools-sidebar__category summary::before {
    content: "▸";
    color: var(--color-accent);
    font-size: 0.7rem;
    line-height: 1;
  }

  .tools-sidebar__category[open] summary::before {
    content: "▾";
  }

  .tools-sidebar__category-name {
    flex: 1;
    min-width: 0;
  }

  .tools-sidebar__category-count {
    color: var(--color-ink-muted);
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
  }

  .tools-sidebar__list {
    list-style: none;
    margin: 0;
    padding: 0 0 var(--space-sm);
    display: grid;
    gap: 1px;
  }

  .tools-sidebar__item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    min-width: 0;
    padding: 0.45rem 0.35rem;
    border-left: 1px solid transparent;
    color: var(--color-ink);
    font-size: 0.8125rem;
    line-height: 1.35;
    text-decoration: none;
    transition:
      color var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out),
      background-color var(--duration) var(--ease-out);
  }

  .tools-sidebar__item-label {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tools-sidebar__item.is-available:hover {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-spot) 45%, transparent);
  }

  .tools-sidebar__item.is-active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-spot) 55%, transparent);
  }

  .tools-sidebar__item.is-wip {
    color: color-mix(in srgb, var(--color-ink-muted) 85%, transparent);
    cursor: default;
    opacity: 0.72;
  }

  .tools-sidebar__badge {
    flex: 0 0 auto;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
</style>
