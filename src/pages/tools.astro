---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/react/PageIntro";
---

<BaseLayout
  title="Tools"
  description="Upcoming tools from dmeim — verification, utilities, and experiments."
>
  <section class="tools-page">
    <PageIntro
      client:visible
      title="Tools"
      lede="A future shelf for verification helpers, key utilities, and small edge experiments."
    />

    <div class="tools-grid">
      <article class="tool-slot">
        <p class="tool-slot__eyebrow">01 · Planned</p>
        <h2 class="tool-slot__title">Signature verify</h2>
        <p class="tool-slot__body">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. In-browser
          checks for OpenPGP and SSH/Ed25519 signatures — coming later.
        </p>
      </article>
      <article class="tool-slot">
        <p class="tool-slot__eyebrow">02 · Planned</p>
        <h2 class="tool-slot__title">Fingerprint card</h2>
        <p class="tool-slot__body">
          Ut enim ad minim veniam, quis nostrud exercitation. Printable or
          shareable fingerprint cards for SSH and GPG identities.
        </p>
      </article>
      <article class="tool-slot">
        <p class="tool-slot__eyebrow">03 · Placeholder</p>
        <h2 class="tool-slot__title">Edge notebook</h2>
        <p class="tool-slot__body">
          Duis aute irure dolor in reprehenderit in voluptate velit esse cillum
          dolore. Scratch space for Workers-side utilities and demos.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .tools-page {
    display: grid;
    gap: var(--space-2xl);
  }

  .tools-page :global(.page-intro) {
    margin-bottom: 0;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-xl);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-2xl);
  }

  .tool-slot {
    display: grid;
    gap: var(--space-sm);
    align-content: start;
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .tool-slot__eyebrow {
    margin: 0;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .tool-slot__title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.4rem, 2.4vw, 1.75rem);
    letter-spacing: -0.01em;
  }

  .tool-slot__body {
    margin: 0;
    max-width: 34ch;
    color: var(--color-ink-muted);
    font-size: 0.9875rem;
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .tools-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
